# Unified IoT Portal env template

# Core service ports/DB
GO_PORT=8081
REDIS_URL=redis://redis:6379
TIMESCALE_URI=postgres://postgres:password@timescaledb:5432/telemetry
POSTGRES_PASSWORD=password
POSTGRES_DB=telemetry

# MQTT internal
MQTT_HOST=emqx
MQTT_PORT=1883
MQTT_URL=tcp://emqx:1883
SERVICE_MQTT_USERNAME=backend-service
SERVICE_MQTT_PASSWORD=change-me
SERVICE_MQTT_PUB_TOPICS=+/ondemand,channels/+/alerts
SERVICE_MQTT_SUB_TOPICS=+/heartbeat,+/data,+/daq,+/ondemand,+/errors,channels/+/messages/+,devices/+/telemetry,channels/+/commands/+/resp,channels/+/commands/+/ack,channels/+/alerts

# Public MQTT hints (for clients/frontends)
MQTT_PUBLIC_HOST=rms-iot.local
MQTT_PUBLIC_PORT=18883
MQTT_PUBLIC_PROTOCOL=mqtts

# Optional: enable channels/* and devices/* compatibility MQTT subscriptions.
# Default is legacy-only (<IMEI>/*). Set to true only when you need compat topics.
MQTT_COMPAT_TOPICS_ENABLED=false
MQTT_PUBLIC_WS_URL=wss://rms-iot.local:7443/mqtt

# EMQX API/Dashboard
EMQX_API_URL=http://emqx:18083/api/v5
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=public
EMQX_APP_ID=admin
EMQX_APP_SECRET=public

# Device credential key
GOVT_CREDS_KEY=changeme-govt-creds-key

# Frontend origins (CORS) and Vite hint
FRONTEND_ORIGINS=http://localhost:5173
VITE_URL=http://localhost:5173
