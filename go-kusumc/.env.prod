# Remote VM / trial env (set real secrets before use)
GO_PORT=8081
REDIS_URL=redis://redis:6379
TIMESCALE_URI=postgres://postgres:password@timescaledb:5432/telemetry
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=telemetry

MQTT_HOST=emqx
MQTT_PORT=1883
MQTT_URL=tcp://emqx:1883
SERVICE_MQTT_USERNAME=backend-service
SERVICE_MQTT_PASSWORD=change-me-mqtt-password
SERVICE_MQTT_PUB_TOPICS=+/ondemand,channels/+/alerts
SERVICE_MQTT_SUB_TOPICS=+/heartbeat,+/data,+/daq,+/ondemand,+/errors,channels/+/messages/+,devices/+/telemetry,channels/+/commands/+/resp,channels/+/commands/+/ack,channels/+/alerts

MQTT_PUBLIC_HOST=mqtt-kusumc.hkbase.in
MQTT_PUBLIC_PORT=8883
MQTT_PUBLIC_PROTOCOL=mqtts

MQTT_COMPAT_TOPICS_ENABLED=false
MQTT_PUBLIC_WS_URL=wss://mqtt-kusumc.hkbase.in/mqtt

EMQX_API_URL=http://emqx:18083/api/v5
EMQX_DASHBOARD_USER=emqx-admin
EMQX_DASHBOARD_PASSWORD=change-me-emqx-dash
EMQX_APP_ID=admin
EMQX_APP_SECRET=change-me-emqx-app-secret

GOVT_CREDS_KEY=change-me-govt-creds-key

FRONTEND_ORIGINS=https://ui-kusumc.hkbase.in
VITE_URL=https://ui-kusumc.hkbase.in

# Dedicated public endpoints
PUBLIC_API_BASE_URL=https://api-kusumc.hkbase.in
PUBLIC_UI_BASE_URL=https://ui-kusumc.hkbase.in
PUBLIC_MQTT_BASE_URL=mqtt-kusumc.hkbase.in

# Deployment cert source (fresh certs are in repo root certs/wildcard.hkbase.in)
DEPLOY_CERTS_DIR=../../certs/wildcard.hkbase.in
NGINX_SSL_CERT=/etc/deploy-certs/fullchain.pem
NGINX_SSL_KEY=/etc/deploy-certs/privkey.pem
EMQX_SSL_CERTFILE=/opt/deploy-certs/fullchain.pem
EMQX_SSL_KEYFILE=/opt/deploy-certs/privkey.pem
EMQX_WSS_CERTFILE=/opt/deploy-certs/fullchain.pem
EMQX_WSS_KEYFILE=/opt/deploy-certs/privkey.pem
