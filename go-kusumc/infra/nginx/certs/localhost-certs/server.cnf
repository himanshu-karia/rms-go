[req]
default_bits = 2048
prompt = no
default_md = sha256
req_extensions = v3_req
distinguished_name = dn

[dn]
C = IN
ST = Maharashtra
L = Pune
O = Unified IoT Local
OU = Dev Server
CN = 192.168.1.5

[v3_req]
keyUsage = critical, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth
subjectAltName = @alt_names

[alt_names]
IP.1 = 192.168.1.5
IP.2 = 127.0.0.1
DNS.1 = localhost
DNS.2 = host.docker.internal
DNS.3 = rms-iot.local
